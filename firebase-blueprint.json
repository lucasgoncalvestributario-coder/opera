{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User shared data and settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "baseSalary": { "type": "number" },
        "salesTarget": { "type": "number" },
        "cityTravelBonus": { "type": "number" },
        "commissionPerSale": { "type": "number" },
        "bonusEAD15": { "type": "number" },
        "bonusTotal25": { "type": "number" },
        "bonusTotal35": { "type": "number" },
        "rules": {
          "type": "object",
          "properties": {
            "cities": {
              "type": "object",
              "properties": {
                "Londrina": { "type": "boolean" },
                "Curitiba": { "type": "boolean" },
                "Maringá": { "type": "boolean" },
                "Toledo": { "type": "boolean" }
              }
            },
            "enableBonusEAD15": { "type": "boolean" },
            "enableBonusTotal25": { "type": "boolean" },
            "enableBonusTotal35": { "type": "boolean" }
          }
        }
      },
      "required": ["userId", "name"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "Individual sale record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "clientName": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Presencial", "EAD"] },
        "status": { "type": "string", "enum": ["Pendente", "Pago"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientName", "city", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and settings"
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "User sales records"
    }
  }
}
