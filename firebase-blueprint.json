{
  "entities": {
    "UserSettings": {
      "title": "User Settings",
      "description": "User specific settings and profile info",
      "type": "object",
      "properties": {
        "baseSalary": { "type": "number" },
        "salesTarget": { "type": "number" },
        "cityTravelBonus": { "type": "number" },
        "commissionPerSale": { "type": "number" },
        "bonusEAD15": { "type": "number" },
        "bonusTotal25": { "type": "number" },
        "bonusTotal35": { "type": "number" },
        "cities": { "type": "object" },
        "enableBonusEAD15": { "type": "boolean" },
        "enableBonusTotal25": { "type": "boolean" },
        "enableBonusTotal35": { "type": "boolean" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Individual sales record",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "city": { "type": "string" },
        "type": { "type": "string", "enum": ["Presencial", "EAD"] },
        "status": { "type": "string", "enum": ["Pendente", "Pago"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["clientName", "city", "type", "status", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserSettings",
      "description": "User profile and settings"
    },
    "users/{userId}/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records for a specific user"
    }
  }
}
